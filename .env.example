
DB_HOST=


DB_USER=

DB_PASSWORD=


DB_NAME=

DB_PORT=3306
DB_SSL=false

DB_PERSONAL_NAME=


# Formato MySQL:
# mysql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BASE
#
# Ejemplo producción:
# mysql://control_stock_user:claveSegura123@127.0.0.1:3306/control_stock_db
DATABASE_URL=
AUTH_SECRET=
FIRST_ADMIN_USER=
FIRST_ADMIN_PASSWORD=

# ==================================
# URL PÚBLICA DE LA APLICACIÓN (FRONT)
# ==================================
# URL completa en la que se va a acceder a la app DESDE EL NAVEGADOR.
# Se usa para generar enlaces que se comparten (ej: crear-password).
#
# - En desarrollo local:
#   http://localhost:3000
#
# - En producción (con HTTPS configurado):
#   https://inventario-demo.tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prefijo público por el que Apache expone Next (ej: /inventory-demo)
# En Render normalmente dejalo vacío (raíz "/")
NEXT_PUBLIC_BASE_PATH=